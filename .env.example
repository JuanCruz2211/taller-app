# Neon PostgreSQL connection string (pooled URL recommended for serverless)
DATABASE_URL=postgresql://user:password@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Better Auth secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=your-secret-here

# Better Auth base URL (for emails, redirects)
BETTER_AUTH_URL=http://localhost:3000

# Better Auth client URL (must match BETTER_AUTH_URL)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
